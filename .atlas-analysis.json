  "keyFeatures": [
    "JWT-based authentication with bcrypt password hashing",
    "API key authentication for public endpoints",
    "RESTful API design with Express.js",
    "MySQL database integration with connection pooling",
    "Rate limiting for API protection",
    "File upload support with Multer for product images and profile photos",
    "Shopping cart and order management",
    "Product reviews and ratings",
    "User address management",
    "OpenAPI/Swagger documentation"
  ],
  "publicApiSurface": [
    "POST /api/register - User registration",
    "POST /api/login - User login",
    "GET /api/user - Get user profile",
    "PATCH /api/user - Update user profile",
    "PATCH /api/user/password - Update password",
    "POST /api/user/profile-photo - Upload profile photo",
    "GET /api/category - Get all categories",
    "POST /api/admin/category - Create category (admin)",
    "GET /api/product - Get all products",
    "GET /api/product/:slug - Get product details",
    "POST /api/admin/product - Create product (admin)",
    "POST /api/review - Add product review",
    "GET /api/cart - Get user cart",
    "POST /api/cart - Add item to cart",
    "DELETE /api/cart - Remove item from cart",
    "GET /api/address - Get user addresses",
    "POST /api/address - Create address",
    "PATCH /api/address - Update address",
    "DELETE /api/address - Delete address"
  ]
